{
  "name": "friendchat-backend",
  "version": "1.0.0",
  "description": "Friend-only messaging API — Node.js / Express / MongoDB / Socket.IO / CometChat",
  "main": "dist/server.js",
  "scripts": {
    "dev":            "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build":          "tsc --project tsconfig.json",
    "start":          "node dist/server.js",
    "lint":           "eslint 'src/**/*.ts' --fix",
    "test":           "jest --runInBand --forceExit --detectOpenHandles",
    "test:unit":      "jest --testPathPattern=tests/unit --runInBand",
    "test:integration":"jest --testPathPattern=tests/integration --runInBand",
    "seed":           "ts-node -r tsconfig-paths/register scripts/seed.ts"
  },
  "dependencies": {
    "bcryptjs":              "^2.4.3",
    "compression":           "^1.7.4",
    "cookie-parser":         "^1.4.6",
    "cors":                  "^2.8.5",
    "dotenv":                "^16.3.1",
    "express":               "^4.18.2",
    "express-async-errors":  "^3.1.1",
    "express-mongo-sanitize":"^2.2.0",
    "express-rate-limit":    "^7.1.5",
    "helmet":                "^7.1.0",
    "http-status-codes":     "^2.3.0",
    "joi":                   "^17.11.0",
    "jsonwebtoken":          "^9.0.2",
    "mongoose":              "^8.0.3",
    "morgan":                "^1.10.0",
    "socket.io":             "^4.6.2",
    "winston":               "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/bcryptjs":        "^2.4.6",
    "@types/compression":     "^1.7.5",
    "@types/cookie-parser":   "^1.4.6",
    "@types/cors":            "^2.8.17",
    "@types/express":         "^4.17.21",
    "@types/jest":            "^29.5.11",
    "@types/jsonwebtoken":    "^9.0.5",
    "@types/morgan":          "^1.9.9",
    "@types/node":            "^20.10.6",
    "@types/supertest":       "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser":        "^6.17.0",
    "eslint":                 "^8.56.0",
    "jest":                   "^29.7.0",
    "mongodb-memory-server":  "^9.1.6",
    "supertest":              "^6.3.4",
    "ts-jest":                "^29.1.1",
    "ts-node-dev":            "^2.0.0",
    "tsconfig-paths":         "^4.2.0",
    "typescript":             "^5.3.3"
  }
}
